From 3c4caf18b610d7936188924e706a3735880fd1dc Mon Sep 17 00:00:00 2001
From: chlorodose <chlorodose@chlorodose.me>
Date: Wed, 24 Jun 2026 10:12:33 +0800
Subject: [PATCH 1/4] Use zstd for module compressing

---
 redhat/configs/common/generic/CONFIG_MODULE_COMPRESS_XZ   | 2 +-
 redhat/configs/common/generic/CONFIG_MODULE_COMPRESS_ZSTD | 2 +-
 redhat/kernel.spec.template                               | 8 ++++----
 3 files changed, 6 insertions(+), 6 deletions(-)

diff --git a/redhat/configs/common/generic/CONFIG_MODULE_COMPRESS_XZ b/redhat/configs/common/generic/CONFIG_MODULE_COMPRESS_XZ
index 880ce085f..d554be9bc 100644
--- a/redhat/configs/common/generic/CONFIG_MODULE_COMPRESS_XZ
+++ b/redhat/configs/common/generic/CONFIG_MODULE_COMPRESS_XZ
@@ -1 +1 @@
-CONFIG_MODULE_COMPRESS_XZ=y
+# CONFIG_MODULE_COMPRESS_XZ is not set
diff --git a/redhat/configs/common/generic/CONFIG_MODULE_COMPRESS_ZSTD b/redhat/configs/common/generic/CONFIG_MODULE_COMPRESS_ZSTD
index 4f5f059b8..bc14d234e 100644
--- a/redhat/configs/common/generic/CONFIG_MODULE_COMPRESS_ZSTD
+++ b/redhat/configs/common/generic/CONFIG_MODULE_COMPRESS_ZSTD
@@ -1 +1 @@
-# CONFIG_MODULE_COMPRESS_ZSTD is not set
+CONFIG_MODULE_COMPRESS_ZSTD=y
diff --git a/redhat/kernel.spec.template b/redhat/kernel.spec.template
index 4c7c1449e..3228af632 100644
--- a/redhat/kernel.spec.template
+++ b/redhat/kernel.spec.template
@@ -147,9 +147,9 @@ Summary: The Linux kernel
 %endif
 
 # Default compression algorithm
-%global compression xz
-%global compression_flags --compress --check=crc32 --lzma2=dict=1MiB
-%global compext xz
+%global compression zstd
+%global compression_flags --rm --ultra -22 --long -T0
+%global compext zst
 
 %if 0%{?fedora}
 %define primary_target fedora
@@ -527,7 +527,7 @@ Summary: The Linux kernel
 %if %{with_automotive}
 # overrides compression algorithms for automotive
 %global compression zstd
-%global compression_flags --rm
+%global compression_flags --rm --ultra -22 --long -T0
 %global compext zst
 
 # automotive does not support the following variants
-- 
2.54.0

From be168d8c69c5f5ae40b957f628abcaed210d29bb Mon Sep 17 00:00:00 2001
From: chlorodose <chlorodose@chlorodose.me>
Date: Wed, 24 Jun 2026 10:22:50 +0800
Subject: [PATCH 2/4] Use clang by default

---
 redhat/kernel.spec.template | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/redhat/kernel.spec.template b/redhat/kernel.spec.template
index 3228af632..d3f51bed0 100644
--- a/redhat/kernel.spec.template
+++ b/redhat/kernel.spec.template
@@ -13,14 +13,18 @@
 %global _lto_cflags %{nil}
 
 # Option to enable compiling with clang instead of gcc.
-%bcond_with toolchain_clang
+%bcond_without toolchain_clang
 
 %if %{with toolchain_clang}
 %global toolchain clang
 %endif
 
 # Compile the kernel with LTO (only supported when building with clang).
+%if %{with toolchain_clang}
+%bcond_without clang_lto
+%else
 %bcond_with clang_lto
+%endif
 
 %if %{with clang_lto} && %{without toolchain_clang}
 {error:clang_lto requires --with toolchain_clang}
-- 
2.54.0

From a40a1042dfbace45d05f5198b8b3db7db58eb1c0 Mon Sep 17 00:00:00 2001
From: chlorodose <chlorodose@chlorodose.me>
Date: Wed, 24 Jun 2026 12:13:14 +0800
Subject: [PATCH 3/4] Remove early defined distro info

---
 redhat/Makefile | 14 +-------------
 1 file changed, 1 insertion(+), 13 deletions(-)

diff --git a/redhat/Makefile b/redhat/Makefile
index 57a884cd1..3589a60b6 100644
--- a/redhat/Makefile
+++ b/redhat/Makefile
@@ -98,18 +98,6 @@ DIST_USERDEF:=$(DIST)
 BUILD_PROFILE_USERDEF:=$(BUILD_PROFILE)
 BUILD_TARGET_USERDEF:=$(BUILD_TARGET)
 
-ifndef DIST
-  DIST := $(shell $(RPMBUILD) --eval '%{?dist}')
-endif
-
-ifndef DISTRO
-  ifneq ($(findstring .fc,$(DIST)),)
-    DISTRO := fedora
-  else
-    DISTRO := rhel
-  endif
-endif
-
 ifndef RHJOBS
   RHJOBS=$(shell j=$$(echo $(MAKEFLAGS) | grep -Eo "(^|[ ])-j[0-9]*" | xargs ); \
 	  if [ -z "$${j}" ]; then \
@@ -831,7 +819,7 @@ dist-spec: ##build Create just the spec file in redhat/rpm/SOURCES/.
 dist-spec: setup-source
 
 do-rpmbuild: dist-sources
-	$(RPMBUILD) --define "_sourcedir $(SOURCES)" --define "_builddir $(RPM)/BUILD" --define "_srcrpmdir $(RPM)/SRPMS" --define "_rpmdir $(RPM)/RPMS" --define "_specdir $(RPM)/SPECS" --define "dist $(DIST)" $(RPMBUILDOPTS) $(RPM)/SOURCES/$(SPECFILE)
+	$(RPMBUILD) --define "_sourcedir $(SOURCES)" --define "_builddir $(RPM)/BUILD" --define "_srcrpmdir $(RPM)/SRPMS" --define "_rpmdir $(RPM)/RPMS" --define "_specdir $(RPM)/SPECS" $(RPMBUILDOPTS) $(RPM)/SOURCES/$(SPECFILE)
 
 dist-all-rpms: ##build Create the binary RPMS and the SRPM for the kernel.  See the dist-brew target for available options.
 dist-all-rpms: RPMBUILDOPTS=--target $(MACH) -ba
-- 
2.54.0

From 3ab62aed439e8f66458f37c6f6b0bc73a40a67dc Mon Sep 17 00:00:00 2001
From: chlorodose <chlorodose@chlorodose.me>
Date: Wed, 24 Jun 2026 13:41:45 +0800
Subject: [PATCH 4/4] Disable debug build by default

---
 redhat/kernel.spec.template | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/redhat/kernel.spec.template b/redhat/kernel.spec.template
index d3f51bed0..cd042e32b 100644
--- a/redhat/kernel.spec.template
+++ b/redhat/kernel.spec.template
@@ -240,7 +240,7 @@ Summary: The Linux kernel
 #      with_base controls base vs debug within those variants
 %define with_base      %{?_without_base:      0} %{?!_without_base:      1}
 # build also debug variants
-%define with_debug     %{?_without_debug:     0} %{?!_without_debug:     1}
+%define with_debug     %{?_with_debug:     1} %{?!_with_debug:     0}
 # kernel-zfcpdump (s390 specific kernel for zfcpdump)
 %define with_zfcpdump  %{?_without_zfcpdump:  0} %{?!_without_zfcpdump:  1}
 # kernel-16k (aarch64 kernel with 16K page_size)
-- 
2.54.0

